{
  "name": "pp",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "del": "rimraf --glob \"**/node_modules\" \"**/dist\" \"**/build\" && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.8.0",
    "eslint": "^10.4.0",
    "prettier": "^3.7.4",
    "turbo": "^2.9.14",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "hono": "^4.12.19",
    "tailwindcss": "^4.3.0"
  }
}
